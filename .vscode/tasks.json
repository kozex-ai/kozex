{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-opencoze-debug",
      "type": "shell",
      "command": "nice",
      "args": [
        "-n",
        "15",
        "go",
        "build",
        "-gcflags=all=-N -l",
        "-o",
        "${workspaceFolder}/bin/opencoze-debug",
        "main.go"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "GOMAXPROCS": "4",
          "GOGC": "50"
        }
      },
      "group": "build",
      "problemMatcher": ["$go"]
    }
  ]
}
